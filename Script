local function FindNewHiderTarget()
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= lp and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local hum = p.Character:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health > 0 and IsHider(p) then
                return p
            end
        end
    end
    return nil
end

local function StartStalkingHider()
    if Settings.StalkConnection then
        Settings.StalkConnection:Disconnect()
        Settings.StalkConnection = nil
    end
    
    if not Settings.StalkHider then return end
    
    local targetHider = FindNewHiderTarget()
    
    if targetHider then
        Settings.CurrentTargetHider = targetHider
        
        local char = lp.Character
        if char then
            local knife = char:FindFirstChild("Couteau") or char:FindFirstChild("Knife")
            if not knife then
                local backpack = lp:FindFirstChild("Backpack")
                if backpack then
                    knife = backpack:FindFirstChild("Couteau") or backpack:FindFirstChild("Knife")
                    if knife then
                        knife.Parent = char
                    end
                end
            end
        end
        
        Settings.StalkConnection = RunService.Heartbeat:Connect(function()
            if not Settings.StalkHider then
                if Settings.StalkConnection then
                    Settings.StalkConnection:Disconnect()
                    Settings.StalkConnection = nil
                end
                return
            end
            
            local targetChar = Settings.CurrentTargetHider and Settings.CurrentTargetHider.Character
            local targetHRP = targetChar and targetChar:FindFirstChild("HumanoidRootPart")
            local targetHum = targetChar and targetChar:FindFirstChildOfClass("Humanoid")
            
            if not targetHRP or not targetHum or targetHum.Health <= 0 or not IsHider(Settings.CurrentTargetHider) then
                local newTarget = FindNewHiderTarget()
                if newTarget then
                    Settings.CurrentTargetHider = newTarget
                    targetChar = newTarget.Character
                    targetHRP = targetChar and targetChar:FindFirstChild("HumanoidRootPart")
                else
                    return
                end
            end
            
            local lpChar = lp.Character
            local lpHRP = lpChar and lpChar:FindFirstChild("HumanoidRootPart")
            
            if targetHRP and lpHRP then
                local targetPos = targetHRP.Position
                local targetLook = targetHRP.CFrame.LookVector
                local behindPos = targetPos - (targetLook * 1.5)
                
                lpHRP.CFrame = CFrame.new(behindPos, targetPos)
                
                local knife = lpChar:FindFirstChild("Couteau") or lpChar:FindFirstChild("Knife")
                if knife then
                    lp.Character.Humanoid:EquipTool(knife)
                    task.wait(0.05)
                    local mouse = lp:GetMouse()
                    if mouse then
                        mouse.Button1Down:Fire()
                        task.wait(0.1)
                        mouse.Button1Up:Fire()
                    end
                end
            end
        end)
    end
end

local function StopStalking()
    if Settings.StalkConnection then
        Settings.StalkConnection:Disconnect()
        Settings.StalkConnection = nil
    end
    Settings.CurrentTargetHider = nil
end

