local function CheckBandageInInventory()
    local char = lp.Character
    if char then
        for _, tool in pairs(char:GetChildren()) do
            if tool:IsA("Tool") then
                local toolName = string.lower(tool.Name)
                if toolName == "bandage" or toolName == "bandagerig" then
                    return true
                end
            end
        end
    end
    
    local backpack = lp:FindFirstChild("Backpack")
    if backpack then
        for _, tool in pairs(backpack:GetChildren()) do
            if tool:IsA("Tool") then
                local toolName = string.lower(tool.Name)
                if toolName == "bandage" or toolName == "bandagerig" then
                    return true
                end
            end
        end
    end
    
    return false
end

task.spawn(function()
    while task.wait(0.5) do
        if Settings.AutoFarmBandages then
            if not CheckBandageInInventory() then
                local droppedBandage = nil
                for _, obj in pairs(workspace:GetDescendants()) do
                    if obj:IsA("Model") and obj.Name == "DroppedBandage" then
                        for _, child in pairs(obj:GetChildren()) do
                            if child.Name == "BandageRig" then
                                droppedBandage = obj
                                break
                            end
                        end
                        if droppedBandage then break end
                    end
                end
                
                if droppedBandage then
                    local bandagePos = droppedBandage:FindFirstChild("HumanoidRootPart") or 
                                       droppedBandage:FindFirstChild("Head") or 
                                       droppedBandage:FindFirstChildWhichIsA("BasePart")
                    
                    if bandagePos then
                        local targetCFrame = bandagePos.CFrame * CFrame.new(0, 2, 0)
                        SafeTP(targetCFrame)
                        
                        local startTime = tick()
                        local collected = false
                        repeat
                            task.wait(0.1)
                            if CheckBandageInInventory() then collected = true end
                            if not droppedBandage or not droppedBandage.Parent then break end
                        until collected or (tick() - startTime) > 5
                    end
                end
            end
        end
    end
end)

