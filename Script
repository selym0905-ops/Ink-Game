local AntiRagdollSystem = {
    IsRagdolled = false,
    SavedPosition = nil,
    SavedCFrame = nil,
    RagdollStartTime = 0,
    ForceTPCounter = 0,
    OriginalCollisions = {},
    Active = false,
    LoopConnection = nil,
    StateChangedConnection = nil,
    DescendantAddedConnection = nil
}

local function CleanupAntiRagdoll(char)
    if AntiRagdollSystem.StateChangedConnection then
        AntiRagdollSystem.StateChangedConnection:Disconnect()
        AntiRagdollSystem.StateChangedConnection = nil
    end
    if AntiRagdollSystem.DescendantAddedConnection then
        AntiRagdollSystem.DescendantAddedConnection:Disconnect()
        AntiRagdollSystem.DescendantAddedConnection = nil
    end
    if AntiRagdollSystem.LoopConnection then
        AntiRagdollSystem.LoopConnection:Disconnect()
        AntiRagdollSystem.LoopConnection = nil
    end
    
    if char then
        for _, part in pairs(char:GetChildren()) do
            if part:IsA("BasePart") then
                part.Anchored = false
                if AntiRagdollSystem.OriginalCollisions[part] ~= nil then
                    part.CanCollide = AntiRagdollSystem.OriginalCollisions[part]
                end
            end
        end
    end
    
    AntiRagdollSystem.IsRagdolled = false
    AntiRagdollSystem.SavedPosition = nil
    AntiRagdollSystem.SavedCFrame = nil
    AntiRagdollSystem.Active = false
end

local function SuperAntiRagdoll(char, hum, hrp)
    if not char or not hum or not hrp then return end
    
    CleanupAntiRagdoll(char)
    AntiRagdollSystem.Active = true
    
    hum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
    hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
    hum:SetStateEnabled(Enum.HumanoidStateType.Physics, false)
    hum:SetStateEnabled(Enum.HumanoidStateType.GettingUp, false)
    
    AntiRagdollSystem.StateChangedConnection = hum.StateChanged:Connect(function(oldState, newState)
        if not AntiRagdollSystem.Active then return end
        
        if newState == Enum.HumanoidStateType.Ragdoll or 
           newState == Enum.HumanoidStateType.FallingDown or
           newState == Enum.HumanoidStateType.Physics then
            
            if not AntiRagdollSystem.IsRagdolled then
                AntiRagdollSystem.SavedCFrame = hrp.CFrame
                AntiRagdollSystem.SavedPosition = hrp.Position
                AntiRagdollSystem.IsRagdolled = true
                AntiRagdollSystem.RagdollStartTime = tick()
                AntiRagdollSystem.ForceTPCounter = 0
                
                hrp.Anchored = true
                
                for _, part in pairs(char:GetChildren()) do
                    if part:IsA("BasePart") then
                        part.Anchored = true
                        if not AntiRagdollSystem.OriginalCollisions[part] then
                            AntiRagdollSystem.OriginalCollisions[part] = part.CanCollide
                        end
                        part.CanCollide = false
                    end
                end
                
                hum:ChangeState(Enum.HumanoidStateType.Running)
                hum.PlatformStand = false
                hrp.Velocity = Vector3.zero
                hrp.RotVelocity = Vector3.zero
                
                for _, descendant in pairs(char:GetDescendants()) do
                    if descendant:IsA("BallSocketConstraint") or 
                       descendant:IsA("NoCollisionConstraint") or
                       descendant:IsA("WeldConstraint") and not descendant:IsA("Motor6D") then
                        descendant:Destroy()
                    end
                end
            end
        else
            if AntiRagdollSystem.IsRagdolled then
                task.spawn(function()
                    if not AntiRagdollSystem.Active then return end
                    
                    local currentPos = hrp.Position
                    local savedPos = AntiRagdollSystem.SavedPosition
                    
                    if savedPos then
                        local distance = (currentPos - savedPos).Magnitude
                        
                        if distance > 5 then
                            hrp.Anchored = true
                            task.wait(0.05)
                            hrp.CFrame = AntiRagdollSystem.SavedCFrame
                            hrp.Velocity = Vector3.zero
                            hrp.RotVelocity = Vector3.zero
                            task.wait(0.1)
                            
                            local newDistance = (hrp.Position - savedPos).Magnitude
                            if newDistance > 1 and AntiRagdollSystem.ForceTPCounter < 3 then
                                AntiRagdollSystem.ForceTPCounter = AntiRagdollSystem.ForceTPCounter + 1
                                hrp.Anchored = true
                                task.wait(0.2)
                                hrp.CFrame = AntiRagdollSystem.SavedCFrame
                                task.wait(0.1)
                            end
                        end
                    end
                    
                    task.wait(0.15)
                    for _, part in pairs(char:GetChildren()) do
                        if part:IsA("BasePart") then
                            part.Anchored = false
                            if AntiRagdollSystem.OriginalCollisions[part] ~= nil then
                                part.CanCollide = AntiRagdollSystem.OriginalCollisions[part]
                            end
                        end
                    end
                    
                    AntiRagdollSystem.IsRagdolled = false
                    AntiRagdollSystem.SavedPosition = nil
                    AntiRagdollSystem.SavedCFrame = nil
                end)
            end
        end
    end)
    
    AntiRagdollSystem.LoopConnection = RunService.Heartbeat:Connect(function()
        if not AntiRagdollSystem.Active then return end
        if not char or not char.Parent then return end
        
        if AntiRagdollSystem.IsRagdolled then
            if hrp and not hrp.Anchored then
                hrp.Anchored = true
            end
            
            for _, part in pairs(char:GetChildren()) do
                if part:IsA("BasePart") and not part.Anchored then
                    part.Anchored = true
                end
            end
            
            if AntiRagdollSystem.SavedCFrame and hrp then
                local currentPos = hrp.Position
                local savedPos = AntiRagdollSystem.SavedPosition
                
                if savedPos and (currentPos - savedPos).Magnitude > 3 then
                    hrp.CFrame = AntiRagdollSystem.SavedCFrame
                    hrp.Velocity = Vector3.zero
                end
            end
            
            for _, descendant in pairs(char:GetDescendants()) do
                if descendant:IsA("BallSocketConstraint") or 
                   (descendant:IsA("Motor6D") and descendant.Enabled == false) then
                    descendant:Destroy()
                end
            end
        end
        
        if hum and hum.PlatformStand == true then
            hum.PlatformStand = false
            if not AntiRagdollSystem.IsRagdolled then
                AntiRagdollSystem.SavedCFrame = hrp.CFrame
                AntiRagdollSystem.SavedPosition = hrp.Position
                AntiRagdollSystem.IsRagdolled = true
                hrp.Anchored = true
            end
        end
    end)
    
    AntiRagdollSystem.DescendantAddedConnection = char.DescendantAdded:Connect(function(descendant)
        if not AntiRagdollSystem.Active then return end
        
        if descendant:IsA("BallSocketConstraint") or 
           descendant:IsA("NoCollisionConstraint") then
            descendant:Destroy()
        end
        
        if descendant:IsA("Motor6D") then
            descendant:GetPropertyChangedSignal("Enabled"):Connect(function()
                if not AntiRagdollSystem.Active then return end
                if descendant.Enabled == false then
                    descendant.Enabled = true
                end
            end)
        end
    end)
end

