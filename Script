SectionAnim:AddButton({ Title = "Stop Animation", Callback = function() if Settings.CurrentAnimTrack then Settings.CurrentAnimTrack:Stop() end end })

local SectionPos = UtilsTab:AddSection("Position Finder")
local PosLabel = SectionPos:AddParagraph({ Title = "Current Position", Content = "X: 0, Y: 0, Z: 0" })
SectionPos:AddButton({ Title = "Find Position", Callback = function()
    local char = lp.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if hrp then
        local pos = hrp.Position
        Settings.CurrentPos = string.format("%.2f, %.2f, %.2f", pos.X, pos.Y, pos.Z)
        PosLabel:SetDesc("X: " .. Settings.CurrentPos)
    end
end })
SectionPos:AddButton({ Title = "Copy Position", Callback = function() setclipboard(Settings.CurrentPos) end })

RunService.Heartbeat:Connect(function()
    local char = lp.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if hum and hrp then
        if Settings.AntiRollback then
            local vel = hrp.Velocity
            if vel.Magnitude > 80 and not Settings.FlyEnabled then
                hrp.Velocity = Vector3.new(vel.X * 0.7, vel.Y, vel.Z * 0.7)
            end
        end
        if Settings.WSEnabled and not Settings.FreecamEnabled and not Settings.InfStamina then
            hum.WalkSpeed = Settings.WS
        end
        if Settings.JPEnabled and not Settings.FreecamEnabled then
            hum.JumpPower = Settings.JP
            hum.UseJumpPower = true
        end
        if Settings.Noclip then
            hum:ChangeState(11)
            for _, v in pairs(char:GetChildren()) do
                if v:IsA("BasePart") then v.CanCollide = false end
            end
        end
    end
    if Settings.GravEnabled then workspace.Gravity = Settings.Grav end
end)

UserInputService.JumpRequest:Connect(function()
    if Settings.InfJump and not Settings.FreecamEnabled then
        local hum = lp.Character and lp.Character:FindFirstChildOfClass("Humanoid")
        if hum and tick() - lastJump >= 0.1 then
            hum:ChangeState(3)
            lastJump = tick()
        end
    end
end)

RunService.RenderStepped:Connect(function(dt)
    if Settings.FreecamEnabled then
        local lookCFrame = CFrame.Angles(0, Settings.FreecamRotY, 0) * CFrame.Angles(Settings.FreecamRotX, 0, 0)
        local moveDir = Vector3.new(0,0,0)
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDir = moveDir + lookCFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDir = moveDir - lookCFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDir = moveDir - lookCFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDir = moveDir + lookCFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then moveDir = moveDir + Vector3.new(0,1,0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then moveDir = moveDir - Vector3.new(0,1,0) end
        if moveDir.Magnitude > 0 then FreecamPos = FreecamPos + (moveDir.Unit * (Settings.FreecamSpeed * 2.5)) end
        Camera.CFrame = CFrame.new(FreecamPos) * lookCFrame
    end
    if Settings.FlyEnabled and not Settings.FreecamEnabled then
        local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            hrp.Velocity = Vector3.new(0,0,0)
            local dir = Vector3.new(0,0,0)
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir = dir + Camera.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir = dir - Camera.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir = dir - Camera.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir = dir + Camera.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then dir = dir + Vector3.new(0,1,0) end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then dir = dir - Vector3.new(0,1,0) end
            if dir.Magnitude > 0 then hrp.CFrame = hrp.CFrame + (dir.Unit * Settings.FlySpeed * dt) end
        end
    end
    
    for player, drawings in pairs(ESP_Objects) do
        local char = player.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChild("Humanoid")
        
        if char and hrp and hum and hum.Health > 0 then
            local pos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
            local finalCol = GetESPColor(player)
            
            if Settings.RoleESP then
                drawings.RoleHighlight.Parent = char
                drawings.RoleHighlight.FillColor = GetRoleColor(player)
                drawings.RoleHighlight.FillTransparency = Settings.FillTransparency
                drawings.RoleHighlight.Enabled = true
                drawings.Highlight.Enabled = false
            else
                drawings.RoleHighlight.Enabled = false
            end
            
            if Settings.ESPEnabled and onScreen then
                if Settings.ESPHighlight and not Settings.RoleESP then
                    drawings.Highlight.Parent = char
                    drawings.Highlight.FillColor = finalCol
                    drawings.Highlight.FillTransparency = Settings.FillTransparency
                    drawings.Highlight.Enabled = true
                else
                    drawings.Highlight.Enabled = false
                end
                
                local lpChar = lp.Character
                local lpHRP = lpChar and lpChar:FindFirstChild("HumanoidRootPart")
                local distance = lpHRP and (lpHRP.Position - hrp.Position).Magnitude or 100
                
                local nameSize = math.clamp(20 - (distance / 30), 8, 20)
                local distSize = math.clamp(18 - (distance / 35), 7, 18)
                
                local rightOffset = 50 + (distance / 10)
                local rightOffsetX = pos.X + rightOffset
                if rightOffsetX > Camera.ViewportSize.X - 50 then
                    rightOffsetX = pos.X - rightOffset
                end
                
                local nameY = pos.Y - 30
                local distY = pos.Y - 15
                
                if Settings.ESPNames then
                    drawings.Name.Visible = true
                    drawings.Name.Text = player.Name
                    drawings.Name.Position = Vector2.new(rightOffsetX, nameY)
                    drawings.Name.Color = finalCol
                    drawings.Name.Size = nameSize
                    drawings.Name.Center = false
                else
                    drawings.Name.Visible = false
                end
                
                if Settings.ESPDistance and lpHRP then
                    drawings.Distance.Visible = true
                    drawings.Distance.Text = "[" .. math.floor(distance) .. "m]"
                    drawings.Distance.Position = Vector2.new(rightOffsetX, distY)
                    drawings.Distance.Color = finalCol
                    drawings.Distance.Size = distSize
                    drawings.Distance.Center = false
                else
                    drawings.Distance.Visible = false
                end
                
                local topPos = char:FindFirstChild("Head") and Camera:WorldToViewportPoint(char.Head.Position) or Camera:WorldToViewportPoint(hrp.Position + Vector3.new(0, 2.5, 0))
                local bottomPos = Camera:WorldToViewportPoint(hrp.Position - Vector3.new(0, 2, 0))
                local boxSize = math.abs(topPos.Y - bottomPos.Y)
                
                if Settings.ESPBoxes then
                    drawings.Box.Visible = true
                    drawings.Box.Size = Vector2.new(boxSize * 0.6, boxSize)
                    drawings.Box.Position = Vector2.new(pos.X - (drawings.Box.Size.X / 2), pos.Y - (drawings.Box.Size.Y / 2))
                    drawings.Box.Color = finalCol
                    drawings.Box.Thickness = Settings.BoxThickness
                else
                    drawings.Box.Visible = false
                end
                
                if Settings.ESPTracers then
                    drawings.Tracer.Visible = true
                    drawings.Tracer.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                    drawings.Tracer.To = Vector2.new(pos.X, pos.Y)
                    drawings.Tracer.Color = finalCol
                else
                    drawings.Tracer.Visible = false
                end
            else
                drawings.Highlight.Enabled = false
                drawings.Box.Visible = false
                drawings.Name.Visible = false
                drawings.Distance.Visible = false
                drawings.Tracer.Visible = false
            end
        else
            drawings.RoleHighlight.Enabled = false
            drawings.Highlight.Enabled = false
            drawings.Box.Visible = false
            drawings.Name.Visible = false
            drawings.Distance.Visible = false
            drawings.Tracer.Visible = false
        end
    end
end)

