local function SafeTP(targetCFrame)
    local char = lp.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    hrp.Velocity = Vector3.zero
    hrp.RotVelocity = Vector3.zero
    hrp.Anchored = true
    task.wait(0.05)
    hrp.CFrame = targetCFrame
    task.wait(0.15)
    hrp.Anchored = false
end

-- ============================================================
--  ANTI-RAGDOLL SYSTEM (amélioré)
-- ============================================================
local AntiRagdollSystem = {
    IsRagdolled = false,
    SavedPosition = nil,
    SavedCFrame = nil,
    RagdollStartTime = 0,
    ForceTPCounter = 0,
    OriginalCollisions = {},
    Active = false,
    LoopConnection = nil,
    StateChangedConnection = nil,
    DescendantAddedConnection = nil
}

local function CleanupAntiRagdoll(char)
    if AntiRagdollSystem.StateChangedConnection then
        AntiRagdollSystem.StateChangedConnection:Disconnect()
        AntiRagdollSystem.StateChangedConnection = nil
    end
    if AntiRagdollSystem.DescendantAddedConnection then
        AntiRagdollSystem.DescendantAddedConnection:Disconnect()
        AntiRagdollSystem.DescendantAddedConnection = nil
    end
    if AntiRagdollSystem.LoopConnection then
        AntiRagdollSystem.LoopConnection:Disconnect()
        AntiRagdollSystem.LoopConnection = nil
    end

    if char then
        for _, part in pairs(char:GetChildren()) do
            if part:IsA("BasePart") then
                part.Anchored = false
                if AntiRagdollSystem.OriginalCollisions[part] ~= nil then
                    part.CanCollide = AntiRagdollSystem.OriginalCollisions[part]
                end
            end
        end
    end

    AntiRagdollSystem.IsRagdolled = false
    AntiRagdollSystem.SavedPosition = nil
    AntiRagdollSystem.SavedCFrame = nil
    AntiRagdollSystem.OriginalCollisions = {}
    AntiRagdollSystem.ForceTPCounter = 0
    AntiRagdollSystem.Active = false
end

local function SuperAntiRagdoll(char, hum, hrp)
    if not char or not hum or not hrp then return end

    CleanupAntiRagdoll(char)
    AntiRagdollSystem.Active = true

    -- Désactivation des états ragdoll
    hum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
    hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
    hum:SetStateEnabled(Enum.HumanoidStateType.Physics, false)
    hum:SetStateEnabled(Enum.HumanoidStateType.GettingUp, false)

    -- Fonction interne : figer le personnage proprement
    local function FreezeChar()
        hrp.Anchored = true
        hrp.Velocity = Vector3.zero
        hrp.RotVelocity = Vector3.zero
        for _, part in pairs(char:GetChildren()) do
            if part:IsA("BasePart") then
                part.Anchored = true
                if not AntiRagdollSystem.OriginalCollisions[part] then
                    AntiRagdollSystem.OriginalCollisions[part] = part.CanCollide
                end
                part.CanCollide = false
                part.Velocity = Vector3.zero
                part.RotVelocity = Vector3.zero
            end
        end
    end

    -- Fonction interne : supprimer les contraintes de ragdoll sans toucher aux Motor6D actifs
    local function RemoveRagdollConstraints()
        for _, d in pairs(char:GetDescendants()) do
            if d:IsA("BallSocketConstraint") or d:IsA("NoCollisionConstraint") then
                d:Destroy()
            elseif d:IsA("Motor6D") and d.Enabled == false then
                d.Enabled = true
            end
        end
    end

    -- Fonction interne : dégeler le personnage et restaurer les collisions
    local function UnfreezeChar()
        for _, part in pairs(char:GetChildren()) do
            if part:IsA("BasePart") then
                part.Anchored = false
                if AntiRagdollSystem.OriginalCollisions[part] ~= nil then
                    part.CanCollide = AntiRagdollSystem.OriginalCollisions[part]
                end
            end
        end
        AntiRagdollSystem.OriginalCollisions = {}
    end

    AntiRagdollSystem.StateChangedConnection = hum.StateChanged:Connect(function(_, newState)
        if not AntiRagdollSystem.Active then return end

        local isRagdollState = (
            newState == Enum.HumanoidStateType.Ragdoll or
            newState == Enum.HumanoidStateType.FallingDown or
            newState == Enum.HumanoidStateType.Physics
        )

        if isRagdollState then
            if not AntiRagdollSystem.IsRagdolled then
                -- Sauvegarder la position AVANT de figer
                AntiRagdollSystem.SavedCFrame = hrp.CFrame
                AntiRagdollSystem.SavedPosition = hrp.Position
                AntiRagdollSystem.IsRagdolled = true
                AntiRagdollSystem.RagdollStartTime = tick()
                AntiRagdollSystem.ForceTPCounter = 0

                FreezeChar()
                RemoveRagdollConstraints()

                hum.PlatformStand = false
                task.defer(function()
                    if AntiRagdollSystem.Active then
                        hum:ChangeState(Enum.HumanoidStateType.Running)
                    end
                end)
            end
        else
            if AntiRagdollSystem.IsRagdolled then
                task.spawn(function()
                    if not AntiRagdollSystem.Active then return end

                    -- Vérifier si on a été déplacé pendant le ragdoll
                    local savedPos = AntiRagdollSystem.SavedCFrame
                    if savedPos then
                        local dist = (hrp.Position - savedPos.Position).Magnitude
                        if dist > 3 then
                            hrp.Anchored = true
                            hrp.CFrame = savedPos
                            hrp.Velocity = Vector3.zero
                            hrp.RotVelocity = Vector3.zero
                            task.wait(0.08)

                            -- Double vérification
                            if (hrp.Position - savedPos.Position).Magnitude > 1 and AntiRagdollSystem.ForceTPCounter < 3 then
                                AntiRagdollSystem.ForceTPCounter += 1
                                hrp.CFrame = savedPos
                                task.wait(0.1)
                            end
                        end
                    end

                    task.wait(0.1)
                    UnfreezeChar()

                    AntiRagdollSystem.IsRagdolled = false
                    AntiRagdollSystem.SavedPosition = nil
                    AntiRagdollSystem.SavedCFrame = nil
                end)
            end
        end
    end)

    -- Heartbeat : surveillance légère (optimisé pour éviter le lag)
    local heartbeatThrottle = 0
    AntiRagdollSystem.LoopConnection = RunService.Heartbeat:Connect(function(dt)
        if not AntiRagdollSystem.Active then return end
        if not char or not char.Parent then return end

        heartbeatThrottle += dt
        -- Exécuter la logique lourde toutes les 3 frames environ (~0.05s) pour réduire le lag
        if heartbeatThrottle < 0.05 then return end
        heartbeatThrottle = 0

        if AntiRagdollSystem.IsRagdolled then
            -- Maintenir le freeze
            if hrp and not hrp.Anchored then
                hrp.Anchored = true
                hrp.Velocity = Vector3.zero
            end

            for _, part in pairs(char:GetChildren()) do
                if part:IsA("BasePart") and not part.Anchored then
                    part.Anchored = true
                    part.Velocity = Vector3.zero
                end
            end

            -- Corriger la position si déplacé
            if AntiRagdollSystem.SavedCFrame and hrp then
                if (hrp.Position - AntiRagdollSystem.SavedCFrame.Position).Magnitude > 2 then
                    hrp.CFrame = AntiRagdollSystem.SavedCFrame
                end
            end

            -- Supprimer les contraintes ragdoll ajoutées dynamiquement
            for _, d in pairs(char:GetDescendants()) do
                if d:IsA("BallSocketConstraint") or d:IsA("NoCollisionConstraint") then
                    d:Destroy()
                end
            end
        end

        -- PlatformStand bypass
        if hum and hum.PlatformStand then
            hum.PlatformStand = false
            if not AntiRagdollSystem.IsRagdolled then
                AntiRagdollSystem.SavedCFrame = hrp.CFrame
                AntiRagdollSystem.SavedPosition = hrp.Position
                AntiRagdollSystem.IsRagdolled = true
                hrp.Anchored = true
            end
        end
    end)

    AntiRagdollSystem.DescendantAddedConnection = char.DescendantAdded:Connect(function(descendant)
        if not AntiRagdollSystem.Active then return end

        if descendant:IsA("BallSocketConstraint") or descendant:IsA("NoCollisionConstraint") then
            task.defer(function() if descendant and descendant.Parent then descendant:Destroy() end end)
        end

        if descendant:IsA("Motor6D") then
            descendant:GetPropertyChangedSignal("Enabled"):Connect(function()
                if AntiRagdollSystem.Active and descendant and descendant.Parent then
                    if not descendant.Enabled then
                        descendant.Enabled = true
                    end
                end
            end)
        end
    end)
end

local function SetupAntiRagdoll()
    local char = lp.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if hum and hrp then
        SuperAntiRagdoll(char, hum, hrp)
    end
end

