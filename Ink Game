--  HEARTBEAT PRINCIPAL (optimisé)
-- ============================================================
RunService.Heartbeat:Connect(function()
    local char = lp.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    local hrp = char and char:FindFirstChild("HumanoidRootPart")

    if hum and hrp then
        -- Anti-rollback : limiter la vélocité anormale
        if Settings.AntiRollback and not Settings.FlyEnabled then
            local vel = hrp.Velocity
            local hVel = Vector3.new(vel.X, 0, vel.Z)
            if hVel.Magnitude > 80 then
                hrp.Velocity = Vector3.new(vel.X * 0.7, vel.Y, vel.Z * 0.7)
            end
        end

        -- WalkSpeed : NE PAS écraser InfStamina
        if Settings.WSEnabled and not Settings.FreecamEnabled and not Settings.InfStamina then
            hum.WalkSpeed = Settings.WS
        end

        -- JumpPower
        if Settings.JPEnabled and not Settings.FreecamEnabled then
            hum.JumpPower = Settings.JP
            hum.UseJumpPower = true
        end

        -- Noclip
        if Settings.Noclip then
            hum:ChangeState(11)
            for _, v in pairs(char:GetChildren()) do
                if v:IsA("BasePart") then v.CanCollide = false end
            end
        end
    end

    if Settings.GravEnabled then
        workspace.Gravity = Settings.Grav
    end
end)

