end

local function StartFOVForcing()
    for _, conn in ipairs(fovConnections) do conn:Disconnect() end
    fovConnections = {}
    if Settings.FOVEnabled then
        table.insert(fovConnections, RunService.Heartbeat:Connect(EnforceFOV))
        table.insert(fovConnections, RunService.RenderStepped:Connect(EnforceFOV))
        table.insert(fovConnections, Camera:GetPropertyChangedSignal("FieldOfView"):Connect(function()
            if Settings.FOVEnabled and Camera.FieldOfView ~= Settings.FOVValue then
                task.defer(EnforceFOV)
            end
