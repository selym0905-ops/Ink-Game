-- ============================================================
--  RENDER STEPPED : FREECAM / FLY / ESP
-- ============================================================
RunService.RenderStepped:Connect(function(dt)
    -- Freecam
    if Settings.FreecamEnabled then
        local lookCFrame = CFrame.Angles(0, Settings.FreecamRotY, 0) * CFrame.Angles(Settings.FreecamRotX, 0, 0)
        local moveDir = Vector3.zero
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDir += lookCFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDir -= lookCFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDir -= lookCFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDir += lookCFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then moveDir += Vector3.new(0,1,0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then moveDir -= Vector3.new(0,1,0) end
        if moveDir.Magnitude > 0 then
            FreecamPos += moveDir.Unit * (Settings.FreecamSpeed * 2.5)
        end
        Camera.CFrame = CFrame.new(FreecamPos) * lookCFrame
    end

    -- Fly (amélioré : pas de reset Velocity brut, utilisation du dt)
    if Settings.FlyEnabled and not Settings.FreecamEnabled then
        local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            local dir = Vector3.zero
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir += Camera.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir -= Camera.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir -= Camera.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir += Camera.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then dir += Vector3.new(0,1,0) end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then dir -= Vector3.new(0,1,0) end
            -- Zéro velocité seulement si on bouge activement pour éviter le freeze permanent
            if dir.Magnitude > 0 then
                hrp.Velocity = Vector3.zero
                hrp.CFrame = hrp.CFrame + (dir.Unit * Settings.FlySpeed * dt * 60)
            else
                hrp.Velocity = Vector3.new(0, -1, 0) -- légère gravité pour ne pas flotter
            end
        end
    end

    -- ESP Render
    for player, drawings in pairs(ESP_Objects) do
        local char = player.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChildOfClass("Humanoid")

        if char and hrp and hum and hum.Health > 0 then
            local pos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
            local finalCol = GetESPColor(player)

            -- Role ESP highlight (indépendant du master ESP)
            if Settings.RoleESP then
                if drawings.RoleHighlight.Parent ~= char then
                    drawings.RoleHighlight.Parent = char
                end
                drawings.RoleHighlight.FillColor = GetRoleColor(player)
                drawings.RoleHighlight.FillTransparency = Settings.FillTransparency
                drawings.RoleHighlight.Enabled = true
                drawings.Highlight.Enabled = false
            else
                drawings.RoleHighlight.Enabled = false
            end

            if Settings.ESPEnabled and onScreen then
                -- Highlight body (si role ESP désactivé)
                if Settings.ESPHighlight and not Settings.RoleESP then
                    if drawings.Highlight.Parent ~= char then
                        drawings.Highlight.Parent = char
                    end
                    drawings.Highlight.FillColor = finalCol
                    drawings.Highlight.FillTransparency = Settings.FillTransparency
                    drawings.Highlight.Enabled = true
                else
                    drawings.Highlight.Enabled = false
                end

                local lpChar = lp.Character
                local lpHRP = lpChar and lpChar:FindFirstChild("HumanoidRootPart")
                local distance = lpHRP and (lpHRP.Position - hrp.Position).Magnitude or 100

                local nameSize = math.clamp(20 - (distance / 30), 8, 20)
                local distSize = math.clamp(18 - (distance / 35), 7, 18)

                -- Position texte à droite, en s'adaptant aux bords de l'écran
                local rightOffset = 50 + (distance / 10)
                local rightOffsetX = pos.X + rightOffset
                if rightOffsetX > Camera.ViewportSize.X - 50 then
                    rightOffsetX = pos.X - rightOffset
                end

                if Settings.ESPNames then
                    drawings.Name.Visible = true
                    drawings.Name.Text = player.Name
                    drawings.Name.Position = Vector2.new(rightOffsetX, pos.Y - 30)
                    drawings.Name.Color = finalCol
                    drawings.Name.Size = nameSize
                    drawings.Name.Center = false
                else
                    drawings.Name.Visible = false
                end

                if Settings.ESPDistance and lpHRP then
                    drawings.Distance.Visible = true
                    drawings.Distance.Text = "[" .. math.floor(distance) .. "m]"
                    drawings.Distance.Position = Vector2.new(rightOffsetX, pos.Y - 15)
                    drawings.Distance.Color = finalCol
                    drawings.Distance.Size = distSize
                    drawings.Distance.Center = false
                else
                    drawings.Distance.Visible = false
                end

                -- Box ESP (calcul depuis Head et HRP)
                local head = char:FindFirstChild("Head")
                local topPos = head and select(1, Camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.5, 0))) or select(1, Camera:WorldToViewportPoint(hrp.Position + Vector3.new(0, 2.5, 0)))
                local bottomPos = select(1, Camera:WorldToViewportPoint(hrp.Position - Vector3.new(0, 2, 0)))
                local boxH = math.abs(topPos.Y - bottomPos.Y)

                if Settings.ESPBoxes then
                    drawings.Box.Visible = true
                    drawings.Box.Size = Vector2.new(boxH * 0.6, boxH)
                    drawings.Box.Position = Vector2.new(pos.X - (drawings.Box.Size.X / 2), pos.Y - (drawings.Box.Size.Y / 2))
                    drawings.Box.Color = finalCol
                    drawings.Box.Thickness = Settings.BoxThickness
                else
                    drawings.Box.Visible = false
                end

                if Settings.ESPTracers then
                    drawings.Tracer.Visible = true
                    drawings.Tracer.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                    drawings.Tracer.To = Vector2.new(pos.X, pos.Y)
                    drawings.Tracer.Color = finalCol
                else
                    drawings.Tracer.Visible = false
                end
            else
                drawings.Highlight.Enabled = false
                drawings.Box.Visible = false
                drawings.Name.Visible = false
                drawings.Distance.Visible = false
                drawings.Tracer.Visible = false
            end
        else
            -- Joueur mort ou sans personnage : tout éteindre
            drawings.RoleHighlight.Enabled = false
            drawings.Highlight.Enabled = false
            drawings.Box.Visible = false
