local WorldSection = VisualTab:AddSection("X-Ray")

local xrayConnections = {}
local xrayEnabled = false
local originalProperties = {}

local function SavePartProperties(part)
    if not originalProperties[part] then
        originalProperties[part] = {
            Material = part.Material,
            Transparency = part.Transparency,
            Color = part.Color
        }
    end
end

local function RestorePartProperties()
    for part, props in pairs(originalProperties) do
        if part and part.Parent then
            pcall(function()
                part.Material = props.Material
                part.Transparency = props.Transparency
                part.Color = props.Color
            end)
        end
    end
    originalProperties = {}
end

local function ApplyXRay()
    for _, part in pairs(workspace:GetDescendants()) do
        if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" and not part:IsA("Terrain") then
            SavePartProperties(part)
            part.Material = Enum.Material.ForceField
            part.Transparency = 0.35
        end
    end
end

local function StartXRayMonitoring()
    for _, conn in ipairs(xrayConnections) do conn:Disconnect() end
    xrayConnections = {}
    if xrayEnabled then
        local conn = workspace.DescendantAdded:Connect(function(descendant)
            if descendant:IsA("BasePart") and descendant.Name ~= "HumanoidRootPart" then
                task.wait(0.1)
                if descendant and descendant.Parent then
                    SavePartProperties(descendant)
                    descendant.Material = Enum.Material.ForceField
                    descendant.Transparency = 0.35
                end
            end
        end)
        table.insert(xrayConnections, conn)
    end
end

local xrayToggle = WorldSection:AddToggle("XRayToggle", {
    Title = "X-Ray",
    Description = "Enable to see through walls",
    Default = false
})
xrayToggle:OnChanged(function(enabled)
    xrayEnabled = enabled
    if enabled then
        ApplyXRay()
        StartXRayMonitoring()
    else
        RestorePartProperties()
        for _, conn in ipairs(xrayConnections) do conn:Disconnect() end
        xrayConnections = {}
    end
end)

WorldSection:AddButton({
    Title = "Reset Visuals",
    Callback = function()
        xrayEnabled = false
        xrayToggle:SetValue(false)
        RestorePartProperties()
        for _, conn in ipairs(xrayConnections) do conn:Disconnect() end
        xrayConnections = {}
    end
})

-- === DOUBLE JUMP AVEC COOLDOWN DE 0.1s ===
local parkourJumpConnection = nil
local parkourLandedConnection = nil

-- Ajout d'un cooldown global de 5s pour le backflip et le slide
local abilityCooldown = false
local function startAbilityCooldown()
    if abilityCooldown then return end
    abilityCooldown = true
    task.delay(5, function()
        abilityCooldown = false
    end)
end

local function StopParkourArtist()
    if parkourJumpConnection then parkourJumpConnection:Disconnect() parkourJumpConnection = nil end
    if parkourLandedConnection then parkourLandedConnection:Disconnect() parkourLandedConnection = nil end
    if Settings.ParkourBackflipTrack then
        Settings.ParkourBackflipTrack:Stop()
        Settings.ParkourBackflipTrack = nil
    end
    if Settings.SlideStartAnimTrack then
        Settings.SlideStartAnimTrack:Stop()
        Settings.SlideStartAnimTrack = nil
    end
    if Settings.SlideLoopAnimTrack then
        Settings.SlideLoopAnimTrack:Stop()
        Settings.SlideLoopAnimTrack = nil
    end
    Settings.ParkourJumpCount = 0
    Settings.ParkourSliding = false
end

local function StartParkourDoubleJump()
    if parkourJumpConnection then parkourJumpConnection:Disconnect() end
    if parkourLandedConnection then parkourLandedConnection:Disconnect() end

    parkourJumpConnection = UserInputService.JumpRequest:Connect(function()
        if not Settings.ParkourArtist then return end
        local char = lp.Character
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if not hum or not hrp then return end

        local state = hum:GetState()
        local inAir = (state == Enum.HumanoidStateType.Freefall or state == Enum.HumanoidStateType.Jumping)
        local currentTime = tick()

        if not inAir then
            -- Premier saut normal
            Settings.ParkourJumpCount = 1
            Settings.ParkourLastJumpTime = currentTime
        elseif Settings.ParkourJumpCount == 1 and (currentTime - Settings.ParkourLastJumpTime) >= 0.1 and not abilityCooldown then
            -- Double saut : backflip (uniquement après 0.1s et si cooldown global inactif)
            Settings.ParkourJumpCount = 2
            hum:ChangeState(Enum.HumanoidStateType.Jumping)
            hrp.Velocity = Vector3.new(hrp.Velocity.X, math.max(hrp.Velocity.Y + 30, 30), hrp.Velocity.Z)

            -- Jouer l'anim backflip
            task.spawn(function()
                if Settings.ParkourBackflipTrack then
                    Settings.ParkourBackflipTrack:Stop()
                end
                local anim = Instance.new("Animation")
                anim.AnimationId = "rbxassetid://108249870359826"
                local animator = hum:FindFirstChildOfClass("Animator") or hum:WaitForChild("Animator", 2)
                if animator then
                    Settings.ParkourBackflipTrack = animator:LoadAnimation(anim)
                    Settings.ParkourBackflipTrack.Priority = Enum.AnimationPriority.Action4
                    Settings.ParkourBackflipTrack:Play()
                end
            end)

            -- Démarrer le cooldown global de 5s
            startAbilityCooldown()
        end
    end)

    -- Réinitialiser le compteur au sol
    parkourLandedConnection = RunService.Heartbeat:Connect(function()
        if not Settings.ParkourArtist then return end
        local char = lp.Character
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        if not hum then return end
        local state = hum:GetState()
        if state == Enum.HumanoidStateType.Running or state == Enum.HumanoidStateType.Landed then
            if Settings.ParkourJumpCount == 2 then
                Settings.ParkourJumpCount = 0
                if Settings.ParkourBackflipTrack then
                    Settings.ParkourBackflipTrack:Stop()
                    Settings.ParkourBackflipTrack = nil
                end
            end
        end
    end)
end

-- === SLIDE AVEC VELOCITY ET ANIMATIONS EN 2 PHASES ===
local slideConnection = nil
local slideVelocityConnection = nil

local function DoSlide()
    if abilityCooldown or Settings.ParkourSliding then return end
    local char = lp.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hum or not hrp then return end
    if hum:GetState() == Enum.HumanoidStateType.Freefall then return end

    Settings.ParkourSliding = true
    startAbilityCooldown()  -- Active le cooldown global de 5s

    local animator = hum:FindFirstChildOfClass("Animator") or hum:WaitForChild("Animator", 2)
    
    task.spawn(function()
        local startAnim = Instance.new("Animation")
        startAnim.AnimationId = "rbxassetid://128442665804257"
        if animator then
            Settings.SlideStartAnimTrack = animator:LoadAnimation(startAnim)
            Settings.SlideStartAnimTrack.Priority = Enum.AnimationPriority.Action
            Settings.SlideStartAnimTrack:Play()
            
            Settings.SlideStartAnimTrack.Stopped:Wait()
            
            if Settings.ParkourSliding then
                local loopAnim = Instance.new("Animation")
                loopAnim.AnimationId = "rbxassetid://128442665804258" -- SlidingLoop
                Settings.SlideLoopAnimTrack = animator:LoadAnimation(loopAnim)
                Settings.SlideLoopAnimTrack.Looped = true
                Settings.SlideLoopAnimTrack.Priority = Enum.AnimationPriority.Action
                Settings.SlideLoopAnimTrack:Play()
            end
        end
    end)

    -- Propulsion fluide : interpolation sur 0.35s vers 15 studs/s
    local direction = hrp.CFrame.LookVector
    local startVelocity = hrp.Velocity
    local targetVelocity = Vector3.new(direction.X * 120, startVelocity.Y, direction.Z * 120)
    local elapsed = 0
    local slideDuration = 0.5

    if slideVelocityConnection then slideVelocityConnection:Disconnect() end
    slideVelocityConnection = RunService.Heartbeat:Connect(function(dt)
        if not Settings.ParkourSliding then 
            if slideVelocityConnection then slideVelocityConnection:Disconnect() end
            slideVelocityConnection = nil
            return 
        end
        
        elapsed = elapsed + dt
        local alpha = math.min(elapsed / slideDuration, 1)
        local t = 1 - alpha
        local eased = 1 - t * t * t
        
        if hrp then
            hrp.Velocity = Vector3.new(
                startVelocity.X + (targetVelocity.X - startVelocity.X) * eased,
                hrp.Velocity.Y,
                startVelocity.Z + (targetVelocity.Z - startVelocity.Z) * eased
            )
        end
        
        if alpha >= 1 then
            if slideVelocityConnection then slideVelocityConnection:Disconnect() end
            slideVelocityConnection = nil
            
            task.wait(0.3)
            
            Settings.ParkourSliding = false
            if Settings.SlideLoopAnimTrack then
                Settings.SlideLoopAnimTrack:Stop()
                Settings.SlideLoopAnimTrack = nil
            end
        end
    end)
end

local function StartParkourSlide()
    if slideConnection then slideConnection:Disconnect() end
    slideConnection = UserInputService.InputBegan:Connect(function(input, processed)
        if processed then return end
        if not Settings.ParkourArtist then return end
        if input.KeyCode == Enum.KeyCode.C then
            DoSlide()
        end
    end)
end

-- === SLIDE MOBILE BUTTON (DRAGGABLE, CENTRÉ, NE DISPARAÎT PAS) ===
local slideButton = nil
local dragData = {
    active = false,
    startPos = nil,
    startMouse = nil,
}

local function CreateSlideButton()
    if slideButton then slideButton:Destroy() slideButton = nil end
    if not Settings.ParkourArtist then return end

    local gui = Instance.new("ScreenGui")
    gui.Name = "ParkourSlideGUI"
    gui.ResetOnSpawn = false
    gui.IgnoreGuiInset = true
    gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    gui.Parent = lp:WaitForChild("PlayerGui")

    local btn = Instance.new("TextButton")
    btn.Name = "SlideBtn"
    btn.Size = UDim2.fromOffset(90, 90)
    -- Calculer la position en offset pur pour le centre de l'écran
    local centerX = (gui.AbsoluteSize.X / 2) - 45
    local centerY = (gui.AbsoluteSize.Y / 2) - 45
    btn.Position = UDim2.new(0, centerX, 0, centerY)
    btn.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
    btn.Text = "⬇ SLIDE"
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.TextSize = 15
    btn.Font = Enum.Font.GothamBold
    btn.AutoButtonColor = false
    btn.BorderSizePixel = 0
    btn.Parent = gui

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0.35, 0)
    corner.Parent = btn

    local stroke = Instance.new("UIStroke")
    stroke.Color = Color3.fromRGB(100, 200, 255)
    stroke.Thickness = 2.5
    stroke.Transparency = 0.2
    stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    stroke.Parent = btn

    local grad = Instance.new("UIGradient")
    grad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(50, 140, 255)),
        ColorSequenceKeypoint.new(0.5, Color3.fromRGB(20, 80, 200)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(10, 30, 120)),
    })
    grad.Rotation = 135
    grad.Parent = btn

    -- Gestion du drag simple et efficace
    local function onInputBegan(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragData.active = true
            dragData.startPos = btn.Position
            dragData.startMouse = input.Position
        end
    end

    local function onInputChanged(input)
        if not dragData.active then return end
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            -- Calculer le déplacement
            local delta = input.Position - dragData.startMouse
            
            -- Nouvelle position basée sur l'offset
            local newX = dragData.startPos.X.Offset + delta.X
            local newY = dragData.startPos.Y.Offset + delta.Y
            
            -- Appliquer la nouvelle position
            btn.Position = UDim2.new(0, newX, 0, newY)
        end
    end

    local function onInputEnded(input)
        if not dragData.active then return end
        dragData.active = false
        
        -- Vérifier si c'était un tap (pas de déplacement significatif)
        if dragData.startMouse and input and input.Position then
            local delta = (input.Position - dragData.startMouse).Magnitude
            if delta < 5 then -- Seuil pour considérer comme un tap
                DoSlide()
            end
        end
    end

    btn.InputBegan:Connect(onInputBegan)
    btn.InputChanged:Connect(onInputChanged)
    btn.InputEnded:Connect(onInputEnded)

    -- Feedback visuel
    local function onPress()
        grad.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(0, 220, 80)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(0, 100, 40)),
        })
    end
    
    local function onRelease()
        grad.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(50, 140, 255)),
            ColorSequenceKeypoint.new(0.5, Color3.fromRGB(20, 80, 200)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(10, 30, 120)),
        })
    end

    btn.MouseButton1Down:Connect(onPress)
    btn.MouseButton1Up:Connect(onRelease)
    
    -- Pour le tactile
    btn.TouchTap:Connect(function()
        onPress()
        task.wait(0.1)
        onRelease()
    end)

    slideButton = gui
end

local function DestroySlideButton()
    if slideButton then slideButton:Destroy() slideButton = nil end
end

