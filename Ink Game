local function GetEmotesList()
    local animFolder = ReplicatedStorage:FindFirstChild("Animations")
    if not animFolder then return {} end
    local emotesFolder = animFolder:FindFirstChild("Emotes")
    if not emotesFolder then return {} end
    local emotes = {}
    for _, emote in pairs(emotesFolder:GetChildren()) do
        if emote:IsA("Animation") then table.insert(emotes, emote.Name) end
