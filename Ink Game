local GuardGuns = {
    "Colt M1911","Colt Python 6","Deagle","FN Fal","Five Seven","G3SG1",
    "Glock 17","Golden Deagle","HK416","M4A1","MP5","MP5K","P90",
    "Revolver","Sawn Off","Stim Pistol","Thompson M1A1","Uzi"
}
local MeleeWeapons = {"Knife","Couteau","Fist","Poing"}

local function HasTool(player, list)
    local char = player.Character
    local backpack = player:FindFirstChild("Backpack")
    local function checkIn(container)
        if not container then return false end
        for _, child in pairs(container:GetChildren()) do
            if child:IsA("Tool") then
                for _, name in pairs(list) do
                    if child.Name == name then return true end
                end
            end
        end
        return false
    end
    return checkIn(char) or checkIn(backpack)
end

local function IsGuard(player)
    if HasTool(player, GuardGuns) then return true end
    local char = player.Character
    if not char then return false end
    if char:GetAttribute("TypeOfGuard") then return true end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum then
        local animator = hum:FindFirstChildOfClass("Animator")
        if animator then
            for _, track in pairs(animator:GetPlayingAnimationTracks()) do
                if track.Animation and string.find(tostring(track.Animation.AnimationId), "WalkGuard") then
                    return true
                end
            end
        end
    end
    return false
end

local function IsSeeker(player)
    return HasTool(player, MeleeWeapons)
end

local function IsHider(player)
    return not IsGuard(player) and not IsSeeker(player)
end

local function GetRoleColor(player)
    if IsGuard(player) then return Color3.fromRGB(128, 0, 255)
    elseif IsSeeker(player) then return Color3.fromRGB(255, 0, 0)
    else return Color3.fromRGB(0, 150, 255) end
end

local function GetESPColor(player)
    if Settings.RoleESP then return GetRoleColor(player) end
    return Settings.ESPColor
end

