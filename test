if not game:IsLoaded() then game.Loaded:Wait() end

local WindUI = nil
local function LoadWindUI()
    local links = {
        "https://github.com/Footagesus/WindUI/releases/latest/download/main.lua",
        "https://raw.githubusercontent.com/Footagesus/WindUI/main/source.lua",
    }
    
    for _, link in ipairs(links) do
        local success, result = pcall(function()
            return game:HttpGet(link, true)
        end)
        
        if success and result then
            local loadSuccess, lib = pcall(loadstring, result)
            if loadSuccess and lib then
                WindUI = lib()
                if WindUI and type(WindUI) == "table" and WindUI.CreateWindow then
                    return true
                end
            end
        end
    end
    return false
end

local function CreateBackupUI()
    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "MySuperHub_Backup"
    screenGui.Parent = game:GetService("CoreGui")
    
    local mainFrame = Instance.new("Frame")
    mainFrame.Size = UDim2.new(0, 500, 0, 400)
    mainFrame.Position = UDim2.new(0.5, -250, 0.5, -200)
    mainFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 35)
    mainFrame.BackgroundTransparency = 0.05
    mainFrame.BorderSizePixel = 0
    mainFrame.Parent = screenGui
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 12)
    corner.Parent = mainFrame
    
    local title = Instance.new("TextLabel")
    title.Text = "✨ My Super Hub ✨"
    title.Size = UDim2.new(1, 0, 0, 50)
    title.BackgroundTransparency = 1
    title.TextColor3 = Color3.fromRGB(255, 255, 255)
    title.TextSize = 24
    title.Font = Enum.Font.GothamBold
    title.Parent = mainFrame
    
    local author = Instance.new("TextLabel")
    author.Text = "by .ftgs"
    author.Size = UDim2.new(1, 0, 0, 30)
    author.Position = UDim2.new(0, 0, 0, 45)
    author.BackgroundTransparency = 1
    author.TextColor3 = Color3.fromRGB(150, 150, 150)
    author.TextSize = 14
    author.Font = Enum.Font.Gotham
    author.Parent = mainFrame
    
    local status = Instance.new("TextLabel")
    status.Text = "✅ Hub chargé avec succès !"
    status.Size = UDim2.new(1, -40, 0, 40)
    status.Position = UDim2.new(0, 20, 0, 90)
    status.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
    status.BackgroundTransparency = 0.5
    status.TextColor3 = Color3.fromRGB(100, 255, 100)
    status.TextSize = 14
    status.Font = Enum.Font.Gotham
    status.Parent = mainFrame
    
    local corner2 = Instance.new("UICorner")
    corner2.CornerRadius = UDim.new(0, 8)
    corner2.Parent = status
    
    return screenGui
end

print("Chargement de WindUI...")
if not LoadWindUI() then
    warn("WindUI non chargé, utilisation de l'UI de secours")
    CreateBackupUI()
    pcall(function()
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = "My Super Hub",
            Text = "WindUI non chargé, mode secours activé",
            Duration = 5
        })
    end)
    return
end

